{
  "version": 1,
  "author": "jw364",
  "editor": "wokwi",
  "parts": [
    {
      "type": "wokwi-esp32-s3-devkitc-1",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-pushbutton",
      "id": "btn",
      "top": -60,
      "left": 295,
      "rotate": 90,
      "attrs": { "color": "green" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r_busy",
      "top": 70,
      "left": 370,
      "rotate": 90,
      "attrs": { "value": "10000" }
    },
    {
      "type": "wokwi-sd-card",
      "id": "sd",
      "top": 180,
      "left": 310,
      "attrs": { "root": "sdcard" }
    }
  ],
  "connections": [
    ["btn:1.l", "esp:GPIO1",  "green", ["h0"]],
    ["btn:2.l", "esp:GND.1", "black", ["h0"]],

    ["r_busy:1", "esp:GPIO15", "orange", ["h0"]],
    ["r_busy:2", "esp:3V3",    "red",    ["h0"]],

    ["sd:SCK",  "esp:GPIO6",  "purple", ["h0"]],
    ["sd:MOSI", "esp:GPIO5",  "blue",   ["h0"]],
    ["sd:MISO", "esp:GPIO7",  "cyan",   ["h0"]],
    ["sd:CS",   "esp:GPIO4",  "yellow", ["h0"]],
    ["sd:VCC",  "esp:3V3",   "red",    ["h0"]],
    ["sd:GND",  "esp:GND.1", "black",  ["h0"]]
  ],
  "serialMonitor": {
    "display": "always"
  }
}
